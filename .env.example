# 复制为 .env.local 并填入真实值（.env.local 不会提交 git）

# SysBuilder 后端地址
SYSBUILDER_BACKEND_URL=http://47.79.4.19

# 认证方式二选一：
# 方式 A — API Token（在 SysBuilder 设置页生成，格式 sb_pat_xxxxx）
SYSBUILDER_TOKEN=

# 方式 B — Session Cookie（用于测试：打开 SysBuilder 网页 → F12 →
#   Application → Cookies → 复制 JSESSIONID 的值，填入下方）
# 格式：JSESSIONID=abc123def456...
SYSBUILDER_COOKIE=
